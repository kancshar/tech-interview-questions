# Okta OAuth2 Configuration
OKTA_TOKEN_URL=https://pepsico.oktapreview.com/oauth2/default/v1/token
OKTA_CLIENT_ID=your_client_id
OKTA_CLIENT_SECRET=your_client_secret
OKTA_GRANT_TYPE=client_credentials
OKTA_SCOPE=

# PepGenX Configuration
PEPGENX_HOSTNAME=https://apim-na.qa.mypepsico.com/cgf/pepgenx
PEPGENX_MODEL=gpt-5.2
PEPGENX_PROVIDER=openai
PEPGENX_API_KEY=your_api_key
PEPGENX_TEAM_ID=your_team_id
PEPGENX_PROJECT_ID=your_project_id
